EMAIL_TO=you@example.com
ARXIV_CATEGORIES=cs.LG,cs.AI,q-bio.QM
MAX_RESULTS=10
LOOKBACK_HOURS=24
REQUEST_TIMEOUT=30
STATE_PATH=.state/state.json
